generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id                   String   @id @default(cuid())
  rowNumber            String   @unique
  name                 String
  description          String   @default("")
  listPrice            Int?
  finalPrice           Int?
  discountAvailability String   @default("")
  lastDiscountPercent  Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([name])
  @@index([finalPrice])
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([username])
}
